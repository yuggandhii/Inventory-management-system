// Inventory Management System - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ----- Auth -----
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("staff") // inventory_manager, warehouse_staff, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  otps      Otp[]
  receipts  Receipt[]       @relation("ReceiptCreatedBy")
  deliveries DeliveryOrder[] @relation("DeliveryCreatedBy")
  transfers InternalTransfer[] @relation("TransferCreatedBy")
  adjustments StockAdjustment[] @relation("AdjustmentCreatedBy")
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   // password_reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ----- Products & Categories -----
model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
}

model Product {
  id          String    @id @default(cuid())
  name        String
  sku         String    @unique
  code        String?   // alternate code
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  unitOfMeasure String  @default("unit") // unit, kg, box, etc.
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  stockLevels StockLevel[]
  receiptLines ReceiptLine[]
  deliveryLines DeliveryLine[]
  transferLines     TransferLine[]
  adjustmentLines  StockAdjustmentLine[]
  reorderRule      ProductReorderRule?
}

model ProductReorderRule {
  id          String   @id @default(cuid())
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Float
  maxQuantity Float?
  reorderPoint Float   // trigger alert when stock <= this
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
}

// ----- Warehouses & Stock -----
model Warehouse {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  address     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stockLevels StockLevel[]
  receipts    Receipt[]
  deliverySource DeliveryOrder[] @relation("DeliveryFromWarehouse")
  transferFrom   InternalTransfer[] @relation("TransferFromWarehouse")
  transferTo     InternalTransfer[] @relation("TransferToWarehouse")
  adjustments    StockAdjustment[]
  reorderRules   ProductReorderRule[]
}

model StockLevel {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Float    @default(0)
  updatedAt   DateTime @updatedAt
  @@unique([productId, warehouseId])
}

// ----- Stock Ledger (all movements) -----
model StockMove {
  id            String   @id @default(cuid())
  productId     String
  warehouseId   String
  quantity      Float    // positive = in, negative = out
  referenceType String   // receipt, delivery, transfer_out, transfer_in, adjustment
  referenceId   String
  createdAt     DateTime @default(now())
}

// ----- Operations: Document status -----
// Draft, Waiting, Ready, Done, Canceled

model Receipt {
  id           String   @id @default(cuid())
  number       String   @unique
  status       String   @default("draft") // draft, waiting, ready, done, canceled
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  supplierRef  String?   // supplier name or ref
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  validatedAt  DateTime?
  createdById  String?
  createdBy    User?    @relation("ReceiptCreatedBy", fields: [createdById], references: [id])
  lines        ReceiptLine[]
}

model ReceiptLine {
  id         String   @id @default(cuid())
  receiptId  String
  receipt    Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Float
  unitPrice  Float?
}

model DeliveryOrder {
  id           String   @id @default(cuid())
  number       String   @unique
  status       String   @default("draft")
  warehouseId  String
  warehouse    Warehouse @relation("DeliveryFromWarehouse", fields: [warehouseId], references: [id])
  customerRef  String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  validatedAt  DateTime?
  createdById  String?
  createdBy    User?    @relation("DeliveryCreatedBy", fields: [createdById], references: [id])
  lines        DeliveryLine[]
}

model DeliveryLine {
  id             String         @id @default(cuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity       Float
}

model InternalTransfer {
  id             String   @id @default(cuid())
  number         String   @unique
  status         String   @default("draft")
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  scheduledAt    DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  validatedAt    DateTime?
  createdById    String?
  createdBy      User?    @relation("TransferCreatedBy", fields: [createdById], references: [id])
  lines          TransferLine[]
}

model TransferLine {
  id         String   @id @default(cuid())
  transferId String
  transfer   InternalTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Float
}

model StockAdjustment {
  id           String   @id @default(cuid())
  number       String   @unique
  status       String   @default("draft")
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  reason       String?  // damage, count_correction, etc.
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  validatedAt  DateTime?
  createdById  String?
  createdBy    User?    @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])
  lines        StockAdjustmentLine[]
}

model StockAdjustmentLine {
  id            String   @id @default(cuid())
  adjustmentId  String
  adjustment    StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  countedQuantity Float  // physical count
  previousQuantity Float // system quantity before adjustment
  difference    Float    // counted - previous
}
